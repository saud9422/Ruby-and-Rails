require 'securerandom'

class Transaction1
    @@transaction_history = Hash.new
    attr_accessor :transaction_id,:sender,:receiver,:time,:amount,:operation
    
    def initialize(id, sender,amount,operation,recieve)
        @transaction_id = id
        @sender = sender
        @amount = amount
        @time = Time.now
        @operation = operation
        @receiver = recieve
    end
    
    def self.account_transactions
        puts "Enter the Account Number.."
        account = gets.chomp
        @@transaction_history.each do |key,val|
            
            if val.sender == account
                puts "
                "
                puts "Transaction ID : #{key}"
                puts " objects #{val.inspect}"
                puts "Sender Account number : #{val.sender}"
                puts "reciever Account Number : #{val.receiver}"
                puts "Transaction Amount : #{val.amount}"
                puts "Transaction Operation : #{val.operation}"
                puts "
                "
            end
        end
        puts "in the transaction method"
        
    end
    
    
    def self.display_transaction_history
        if @@transaction_history.empty?
            puts "No transaction is performed..."
        else
            @@transaction_history.each do |key, val|
                  puts "
                "
                puts "Transaction ID : #{key}"
                puts "Sender Account Number #{val.sender}"
                puts "reciever Account Number : #{val.receiver}"
                puts "transaction Amount : #{val.amount}"
                puts "operation : #{val.operation}"
                puts "time : #{val.time}"
                  puts "
                "
            end
        end
        
    end
end




